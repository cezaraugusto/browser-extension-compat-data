{
  "name": "browser-extension-compat-data",
  "description": "Validate WebExtensions manifest (and optionally permissions/APIs) against MDN browser-compat-data",
  "packageManager": "pnpm@9.9.0",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "browser-extension",
    "webextensions",
    "compatibility",
    "manifest",
    "api",
    "mdn",
    "browser-compat-data",
    "analysis",
    "typescript",
    "zero-dependency"
  ],
  "author": "Cezar Augusto",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cezaraugusto/browser-extension-compat-data.git"
  },
  "bugs": {
    "url": "https://github.com/cezaraugusto/browser-extension-compat-data/issues"
  },
  "homepage": "https://github.com/cezaraugusto/browser-extension-compat-data#readme",
  "publishConfig": {
    "provenance": true
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@rslib/core": "^0.9.2",
    "@types/node": "^22.15.30",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1",
    "vitest": "^3.2.2"
  },
  "dependencies": {
    "acorn": "^8.12.1"
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "publish:provenance": "np patch --no-tests --any-branch --yolo --message 'release: %s' --provenance",
    "data:build-index": "pnpm build && node -e 'const m=require(\"./dist/index.cjs\"); if(m.buildPrecomputedIndex){m.buildPrecomputedIndex().then(()=>console.log(\"index built\")).catch(e=>{console.error(e);process.exit(1)})}else{console.error(\"buildPrecomputedIndex not exported\");process.exit(1)}'"
  }
}
